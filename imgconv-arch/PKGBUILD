pkgname=imgconv
pkgver=1.0
pkgrel=1
pkgdesc="Minimal, fast image conversion tool supporting PNG, JPG, WebP, BMP, TGA, PNM, GIF, PSD, HDR"
arch=('x86_64')
url="https://example.com"
license=('MIT')
depends=('libwebp')
makedepends=('gcc' 'make')
source=("imgconv-1.0.tar.gz") #create and put in same folder
md5sums=('SKIP')

build() {
  cd "$srcdir/imgconv"
  make
}

package() {
  cd "$srcdir/imgconv"
  install -Dm755 imgconv "$pkgdir/usr/bin/imgconv"
}
